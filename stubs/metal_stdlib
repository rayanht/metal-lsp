// Half-precision literal suffix: 1.0h → half
// Defined here (not in compat header) to survive clangd preamble serialization.
#pragma clang diagnostic push
#pragma clang diagnostic ignored "-Wuser-defined-literals"
#pragma clang diagnostic ignored "-Wreserved-user-defined-literal"
constexpr metal::half operator""h(long double v) { return (metal::half)v; }
#pragma clang diagnostic pop
